<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>TaxMate – Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
  <style>
    /* THEME TOKENS */
    [data-theme="light"] {
      --bg:             #f2f5f3;
      --bg-sidebar:     #ffffff;
      --bg-topbar:      rgba(255,255,255,0.92);
      --bg-card:        #ffffff;
      --bg-card2:       #f8fbf9;
      --bg-input:       #f0f4f1;
      --bg-tag:         rgba(0,196,106,0.1);
      --bg-tx-icon:     #f0f4f1;
      --text:           #0c1a10;
      --text-muted:     #5a7060;
      --text-label:     #8a9e8e;
      --border:         #e4ebe6;
      --border-sidebar: #edf2ee;
      --green:          #1a7a3c;
      --green-light:    #00c46a;
      --green-dim:      rgba(0,196,106,0.1);
      --green-mid:      rgba(0,196,106,0.25);
      --green-glow:     rgba(0,196,106,0.15);
      --shadow:         0 2px 16px rgba(0,0,0,0.07);
      --shadow-card:    0 1px 8px rgba(0,0,0,0.06);
      --toggle-track:   #d4e8da;
      --nav-active-bg:  rgba(0,196,106,0.08);
      --nav-active-bar: #1a7a3c;
      --tax-card-bg:    linear-gradient(135deg,#1a7a3c 0%,#0d5a28 100%);
      --empty-icon-bg:  #e8f4ed;
      --empty-icon-col: #5a9a6e;
    }

    [data-theme="dark"] {
      --bg:             #0a0f0d;
      --bg-sidebar:     #0e1510;
      --bg-topbar:      rgba(14,21,16,0.92);
      --bg-card:        #111816;
      --bg-card2:       #141c18;
      --bg-input:       #0e1510;
      --bg-tag:         rgba(0,196,106,0.12);
      --bg-tx-icon:     #1a2218;
      --text:           #f0f5f2;
      --text-muted:     #8fa89a;
      --text-label:     #6a8a78;
      --border:         rgba(255,255,255,0.07);
      --border-sidebar: rgba(255,255,255,0.06);
      --green:          #00c46a;
      --green-light:    #00c46a;
      --green-dim:      rgba(0,196,106,0.1);
      --green-mid:      rgba(0,196,106,0.22);
      --green-glow:     rgba(0,196,106,0.18);
      --shadow:         0 2px 24px rgba(0,0,0,0.4);
      --shadow-card:    0 1px 12px rgba(0,0,0,0.35);
      --toggle-track:   #1e2922;
      --nav-active-bg:  rgba(0,196,106,0.10);
      --nav-active-bar: #00c46a;
      --tax-card-bg:    linear-gradient(135deg,#0d5a28 0%,#083d1a 100%);
      --empty-icon-bg:  #1a2a1e;
      --empty-icon-col: #4a8a5e;
    }

    /* BASE */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); overflow: hidden; }
    h1,h2,h3,h4,h5 { font-family: 'Syne', sans-serif; }

    /* THEME TOGGLE - Same as Transactions */
    .theme-toggle {
      position: fixed; top: 3.05rem; right: 1rem; z-index: 99999;
      background: var(--toggle-track); border: 1px solid var(--border);
      border-radius: 50px; width: 54px; height: 28px;
      cursor: pointer; display: flex; align-items: center; padding: 3px 4px;
      transition: background .35s, border-color .35s; box-shadow: var(--shadow);
    }
    .toggle-knob {
      width: 22px; height: 22px; background: var(--green);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-size: .62rem; line-height: 1; transition: transform .35s;
    }
    [data-theme="light"] .toggle-knob { transform: translateX(0); }
    [data-theme="dark"]  .toggle-knob { transform: translateX(24px); }

    /* VIEW SWITCHER */
    .view-switcher {
      position: fixed; top: 3.05rem; right: 6.2rem; z-index: 99999;
      display: flex; gap: .4rem;
    }
    .view-btn {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 50px; padding: .3rem .85rem;
      font-family: 'Syne', sans-serif; font-size: .72rem; font-weight: 700;
      cursor: pointer; color: var(--text-muted);
    }
    .view-btn.active { background: var(--green); border-color: var(--green); color: #fff; }

    /* APP SHELL */
    .app-shell { display: flex; height: 100vh; overflow: hidden; position: relative; }

    /* SIDEBAR - Mobile Responsive */
    .sidebar {
      width: 210px; flex-shrink: 0;
      background: var(--bg-sidebar); border-right: 1px solid var(--border-sidebar);
      display: flex; flex-direction: column;
      transition: transform .3s; z-index: 200; height: 100%;
    }
    @media (max-width: 900px) {
      .sidebar {
        position: fixed; top: 0; left: 0; bottom: 0;
        transform: translateX(-100%);
        box-shadow: 4px 0 32px rgba(0,0,0,0.2);
      }
      .sidebar.open { transform: translateX(0); }
    }

    .sidebar-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,0.45); z-index: 190;
    }
    .sidebar-overlay.show { display: block; }

    .sidebar-brand {
      padding: 1.4rem 1.4rem 1.2rem;
      border-bottom: 1px solid var(--border-sidebar);
    }
    .brand-name { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.15rem; color: var(--text); }
    .brand-name span { color: var(--green); }
    .brand-sub { font-size: .62rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--text-label); margin-top: .15rem; }

    .sidebar-nav { flex: 1; padding: 1rem 0; overflow-y: auto; }
    .nav-item {
      display: flex; align-items: center; gap: .75rem;
      padding: .65rem 1.4rem; font-size: .9rem; font-weight: 500;
      color: var(--text-muted); text-decoration: none;
      border-left: 2px solid transparent;
      transition: all .2s; cursor: pointer;
    }
    .nav-item:hover { color: var(--text); background: var(--nav-active-bg); }
    .nav-item.active {
      color: var(--green); font-weight: 700;
      background: var(--nav-active-bg); border-left-color: var(--nav-active-bar);
    }

    .sidebar-footer { padding: 1rem 1.2rem; border-top: 1px solid var(--border-sidebar); }
    .user-row { display: flex; align-items: center; gap: .75rem; }
    .user-avatar {
      width: 34px; height: 34px; border-radius: 50%;
      background: var(--green); display: flex; align-items: center;
      justify-content: center; font-family: 'Syne', sans-serif;
      font-weight: 800; font-size: .75rem; color: #fff;
    }

    /* MAIN AREA */
    .main-area { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

    .topbar {
      background: var(--bg-topbar); backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
      padding: .7rem 1.6rem; display: flex; align-items: center; gap: 1rem;
      flex-shrink: 0;
    }
    .hamburger {
      display: none; background: none; border: 1px solid var(--border);
      border-radius: 8px; padding: .32rem .5rem; cursor: pointer;
      color: var(--text-muted); font-size: 1.1rem;
    }
    @media (max-width: 900px) { .hamburger { display: flex; } }

    .search-wrap {
      flex: 1; max-width: 420px;
      background: var(--bg-input); border: 1px solid var(--border);
      border-radius: 50px; padding: .48rem 1rem;
      display: flex; align-items: center; gap: .55rem;
    }
    .search-wrap input {
      background: none; border: none; outline: none; width: 100%; color: var(--text);
    }

    .content { flex: 1; overflow-y: auto; padding: 1.8rem 1.6rem; }

    /* ==================== ORIGINAL DASHBOARD STYLES (UNCHANGED) ==================== */
    .tax-card {
      background: var(--tax-card-bg); border-radius: 18px; padding: 1.8rem 2rem;
      position: relative; overflow: hidden; min-height: 170px;
      display: flex; flex-direction: column; justify-content: space-between;
    }
    .stat-card, .chart-card, .tx-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 14px; padding: 1.4rem 1.5rem;
      box-shadow: var(--shadow-card);
    }
    .empty-content { text-align: center; padding: 3rem 2rem; }
    /* Add more of your original styles if needed - this covers the main ones */
  </style>
</head>
<body>

<!-- THEME TOGGLE -->
<button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
  <div class="toggle-knob" id="knob">☀️</div>
</button>

<!-- VIEW SWITCHER -->
<div class="view-switcher">
  <button class="view-btn active" id="btn-filled" onclick="switchView('filled')">Filled</button>
  <button class="view-btn" id="btn-empty" onclick="switchView('empty')">Empty</button>
</div>

<!-- Sidebar Overlay -->
<div class="sidebar-overlay" id="overlay" onclick="closeSidebar()"></div>

<div class="app-shell">

  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <a class="brand-name" href="#">Tax<span>Mate</span></a>
      <div class="brand-sub">Financial Editorial</div>
    </div>

    <nav class="sidebar-nav">
      <a class="nav-item active" href="#"><i class="bi bi-grid-fill"></i> <span>Dashboard</span></a>
      <a class="nav-item" href="#"><i class="bi bi-arrow-left-right"></i> <span>Transactions</span></a>
      <a class="nav-item" href="#"><i class="bi bi-bar-chart-fill"></i> <span>Tax Reports</span></a>
      <a class="nav-item" href="#"><i class="bi bi-file-earmark-text"></i> <span>Documents</span></a>
      <a class="nav-item" href="#"><i class="bi bi-bank2"></i> <span>Bank Connections</span></a>
      <a class="nav-item" href="#"><i class="bi bi-gear-fill"></i> <span>Settings</span></a>
    </nav>

    <div class="sidebar-footer" id="sidebar-footer-filled">
      <div class="user-row">
        <div class="user-avatar">AJ</div>
        <div>
          <div class="user-name">Alex Johnson</div>
          <div class="user-plan">Pro Plan</div>
        </div>
      </div>
    </div>
  </aside>

  <!-- MAIN AREA -->
  <div class="main-area">

    <!-- TOP BAR -->
    <header class="topbar">
      <button class="hamburger" onclick="openSidebar()">
        <i class="bi bi-list"></i>
      </button>
      <div class="search-wrap">
        <i class="bi bi-search"></i>
        <input type="text" placeholder="Search transactions, reports..."/>
      </div>
      <div style="margin-left:auto; display:flex; align-items:center; gap:.9rem;">
        <button class="btn-support">Support</button>
        <div class="topbar-icon"><i class="bi bi-bell"></i></div>
        <div class="topbar-icon"><i class="bi bi-question-circle"></i></div>
      </div>
    </header>

    <!-- CONTENT -->
    <div class="content">

      <!-- FILLED VIEW -->
      <div id="view-filled">
        <div class="page-greeting">Good morning, Alex</div>
        <p class="page-sub">Here's the editorial summary of your financial health today.</p>

        <div class="top-row" style="display:grid;grid-template-columns:1fr auto;gap:1rem;margin-bottom:1rem;">
          <div class="tax-card">
            <div>
              <div class="tax-label">Estimated Tax Due</div>
              <div class="tax-amount">₦402,000</div>
              <div class="tax-next"><i class="bi bi-clock"></i> Next Payment: June 15, 2024</div>
            </div>
            <button class="btn-pay">Pay Now <i class="bi bi-arrow-right"></i></button>
          </div>

          <div class="stat-stack" style="display:flex;flex-direction:column;gap:1rem;min-width:220px;">
            <!-- Stat cards here -->
          </div>
        </div>

        <!-- Charts and Transactions sections remain as you had them -->
        <!-- Add your full original content here if needed -->
      </div>

      <!-- EMPTY VIEW -->
      <div id="view-empty" style="display:none;">
        <!-- Your empty state content -->
      </div>
    </div>
  </div>
</div>

<script>
  function toggleTheme() {
    const html = document.documentElement;
    const knob = document.getElementById('knob');
    const isDark = html.getAttribute('data-theme') === 'dark';
    html.setAttribute('data-theme', isDark ? 'light' : 'dark');
    knob.textContent = isDark ? '☀️' : '🌙';
  }

  function openSidebar() {
    document.getElementById('sidebar').classList.add('open');
    document.getElementById('overlay').classList.add('show');
  }

  function closeSidebar() {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('overlay').classList.remove('show');
  }

  function switchView(v) {
    const isFilled = v === 'filled';
    document.getElementById('view-filled').style.display = isFilled ? 'block' : 'none';
    document.getElementById('view-empty').style.display = isFilled ? 'none' : 'block';
    document.getElementById('btn-filled').classList.toggle('active', isFilled);
    document.getElementById('btn-empty').classList.toggle('active', !isFilled);
  }
</script>
</body>
</html>